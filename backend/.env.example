# DGCPOS Edition: community | enterprise (default enterprise for dgcpos.net SaaS)
DGCPOS_EDITION=community

# Enterprise license (self-hosted EE — optional)
# DGCPOS_LICENSE_KEY=DGC-ENT-...
# DGCPOS_LICENSE_PUBLIC_KEY=   # override embedded verification key (base64 raw or PEM)
# DGCPOS_LICENSE_PRIVATE_KEY=  # issuer only — never commit; used by scripts/license/issue.py
# DGCPOS_LICENSE_SERVER_SECRET= # remote /api/license-server/validate

# Database
DATABASE_URL=sqlite:///retailos.db

# Redis (optional — in-memory fallback)
# REDIS_URL=redis://localhost:6379