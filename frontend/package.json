{
  "name": "dgc-retailos-frontend",
  "private": true,
  "version": "1.2.16",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ce": "VITE_DGCPOS_EDITION=community vite",
    "build": "vite build",
    "build:ce": "VITE_DGCPOS_EDITION=community vite build",
    "build:ee": "VITE_DGCPOS_EDITION=enterprise vite build",
    "build:cap": "CAPACITOR_BUILD=1 vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "audit:prod": "npm audit --omit=dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "quality:check": "npm run lint && npm run test && npm run build && npm run audit:prod",
    "cap:sync": "npm run build:cap && node scripts/cap-prune.mjs && npx cap sync && node scripts/cap-local-plugins.mjs",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android",
    "mobile:assets": "npx capacitor-assets generate --iconBackgroundColor '#071B52' --splashBackgroundColor '#F6F9FC'"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-printer": "^8.1.0",
    "@react-oauth/google": "^0.12.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.5",
    "axios": "^1.18.1",
    "chart.js": "^4.4.2",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.0.8",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^1.22.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^0.19.2",
    "vitest": "^3.2.4"
  }
}
